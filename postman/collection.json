      "item": [
        {
          "name": "GET - Get All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TC-001: Get All Users\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 2000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has data array\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"data\");\r",
                  "    pm.expect(json.data).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Page number is 2\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.page).to.eql(2);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
